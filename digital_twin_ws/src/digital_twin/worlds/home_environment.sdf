      <joint name="left_ankle_pitch" type="revolute"><parent>left_shin</parent><child>left_foot</child><axis><xyz>0 1 0</xyz><limit><lower>-0.5</lower><upper>0.5</upper><effort>50</effort><velocity>2.0</velocity></limit></axis></joint>

      <link name="right_hip"><pose>0.1 0 0.98 0 0 0</pose><inertial><mass>1.0</mass><inertia><ixx>0.003</ixx><iyy>0.003</iyy><izz>0.003</izz></inertia></inertial><visual name="v"><geometry><sphere><radius>0.06</radius></sphere></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual><collision name="c"><geometry><sphere><radius>0.06</radius></sphere></geometry></collision></link>
      <link name="right_thigh"><pose>0.1 0 0.75 0 0 0</pose><inertial><mass>4.0</mass><inertia><ixx>0.05</ixx><iyy>0.05</iyy><izz>0.01</izz></inertia></inertial><visual name="v"><geometry><cylinder><radius>0.055</radius><length>0.38</length></cylinder></geometry><material><ambient>0.75 0.75 0.75 1</ambient><diffuse>0.75 0.75 0.75 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.055</radius><length>0.38</length></cylinder></geometry></collision></link>
      <link name="right_knee"><pose>0.1 0 0.52 0 0 0</pose><inertial><mass>0.5</mass><inertia><ixx>0.001</ixx><iyy>0.001</iyy><izz>0.001</izz></inertia></inertial><visual name="v"><geometry><sphere><radius>0.05</radius></sphere></geometry><material><ambient>0.7 0.7 0.7 1</ambient><diffuse>0.7 0.7 0.7 1</diffuse></material></visual><collision name="c"><geometry><sphere><radius>0.05</radius></sphere></geometry></collision></link>
      <link name="right_shin"><pose>0.1 0 0.3 0 0 0</pose><inertial><mass>3.0</mass><inertia><ixx>0.04</ixx><iyy>0.04</iyy><izz>0.008</izz></inertia></inertial><visual name="v"><geometry><cylinder><radius>0.045</radius><length>0.36</length></cylinder></geometry><material><ambient>0.75 0.75 0.75 1</ambient><diffuse>0.75 0.75 0.75 1</diffuse></material></visual><collision name="c"><geometry><cylinder><radius>0.045</radius><length>0.36</length></cylinder></geometry></collision></link>
      <link name="right_foot"><pose>0.1 0.02 0.08 0 0 0</pose><inertial><mass>1.0</mass><inertia><ixx>0.003</ixx><iyy>0.005</iyy><izz>0.005</izz></inertia></inertial><visual name="v"><geometry><box><size>0.1 0.22 0.06</size></box></geometry><material><ambient>0.3 0.3 0.3 1</ambient><diffuse>0.3 0.3 0.3 1</diffuse></material></visual><collision name="c"><geometry><box><size>0.1 0.22 0.06</size></box></geometry></collision></link>
      <joint name="right_hip_pitch" type="revolute"><parent>torso</parent><child>right_hip</child><pose>0.05 0 -0.02 0 0 0</pose><axis><xyz>0 1 0</xyz><limit><lower>-1.57</lower><upper>1.57</upper><effort>100</effort><velocity>2.0</velocity></limit></axis></joint>
      <joint name="right_hip_to_thigh" type="fixed"><parent>right_hip</parent><child>right_thigh</child></joint>
      <joint name="right_knee_pitch" type="revolute"><parent>right_thigh</parent><child>right_knee</child><axis><xyz>0 1 0</xyz><limit><lower>-2.35</lower><upper>0.05</upper><effort>100</effort><velocity>2.0</velocity></limit></axis></joint>
      <joint name="right_knee_to_shin" type="fixed"><parent>right_knee</parent><child>right_shin</child></joint>
      <joint name="right_ankle_pitch" type="revolute"><parent>right_shin</parent><child>right_foot</child><axis><xyz>0 1 0</xyz><limit><lower>-0.5</lower><upper>0.5</upper><effort>50</effort><velocity>2.0</velocity></limit></axis></joint>

      <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
